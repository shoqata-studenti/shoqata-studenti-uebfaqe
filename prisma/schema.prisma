generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

enum MemberStatus {
  ACTIVE
  EXPIRED
  PENDING
}

enum MembershipType {
  STUDENT
  ALUMNI
}

model Member {
  id            Int              @id @default(autoincrement())
  email         String           @unique
  name          String
  uni           String
  studium       String
  type          MembershipType
  status        MemberStatus     @default(ACTIVE)
  stripeId      String?          @unique
  joinedAt      DateTime         @default(now())
  expiresAt     DateTime?
  lastRenewalAt DateTime        @default(now())
}

model Post {
  id            Int      @id @default(autoincrement())
  title         String
  content       String
  imageMimeType String
  imageData     Bytes
  /// optional: allowlisted /evente/… or /projekte/… — CTA target; /evente/… also lists post on that event page
  cardLinkPath  String?
  /// data e aktivitetit (për seksionin «Në vijim» në ballinë); null = nuk shfaqet atje
  eventAt       DateTime?
  /// vendi (p.sh. Zürich)
  venue         String?
  createdAt     DateTime @default(now())

  @@index([cardLinkPath])
  @@index([eventAt])
}

model VargjetTopic {
  id        Int               @id @default(autoincrement())
  title     String
  slug      String            @unique
  sortOrder Int               @default(0)
  createdAt DateTime          @default(now())
  documents VargjetDocument[]
}

model VargjetDocument {
  id               Int          @id @default(autoincrement())
  topicId          Int
  topic            VargjetTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  title            String
  originalFileName String
  mimeType         String
  fileData         Bytes
  createdAt        DateTime     @default(now())

  @@index([topicId])
}

model EventGalleryImage {
  id          Int      @id @default(autoincrement())
  eventSlug   String
  /// viti i edicionit (p.sh. 2025) — faqja /evente/{slug}/{vit}
  editionYear Int      @default(2024)
  sortOrder   Int      @default(0)
  /// të njëjtin UUID për të gjitha slide-t e një slideshow; null = një media e vetme
  slideshowGroupId String?
  slideshowIndex   Int      @default(0)
  mimeType    String
  fileData    Bytes
  createdAt   DateTime @default(now())

  @@index([eventSlug, editionYear])
  @@index([eventSlug])
  @@index([eventSlug, editionYear, sortOrder])
}