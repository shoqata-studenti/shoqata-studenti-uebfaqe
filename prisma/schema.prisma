generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

enum MemberStatus {
  ACTIVE
  EXPIRED
  PENDING
}

enum MembershipType {
  STUDENT
  ALUMNI
}

model Member {
  id            Int              @id @default(autoincrement())
  email         String           @unique
  name          String
  uni           String
  studium       String
  type          MembershipType
  status        MemberStatus     @default(ACTIVE)
  stripeId      String?          @unique
  joinedAt      DateTime         @default(now())
  expiresAt     DateTime?
  lastRenewalAt DateTime        @default(now())
}

model Post {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  imageUrl  String
  year      Int
  createdAt DateTime @default(now())
}