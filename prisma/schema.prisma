generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

enum MemberStatus {
  ACTIVE
  EXPIRED
  PENDING
}

model Member {
  id        Int          @id @default(autoincrement())
  email     String       @unique
  status    MemberStatus @default(PENDING)
  stripeId  String?      @unique
  joinedAt  DateTime     @default(now())
  expiresAt DateTime?
}

model Post {
  id        Int      @id @default(autoincrement())
  title     String
  content   String  
  imageUrl  String   
  year      Int
  createdAt DateTime @default(now())
}
