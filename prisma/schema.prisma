generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

enum MemberStatus {
  ACTIVE
  EXPIRED
  PENDING
}

enum MembershipType {
  STUDENT
  ALUMNI
}

model Member {
  id            Int              @id @default(autoincrement())
  email         String           @unique
  name          String
  uni           String
  studium       String
  type          MembershipType
  status        MemberStatus     @default(ACTIVE)
  stripeId      String?          @unique
  joinedAt      DateTime         @default(now())
  expiresAt     DateTime?
  lastRenewalAt DateTime        @default(now())
}

model Post {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  imageUrl  String
  year      Int
  createdAt DateTime @default(now())
}

model VargjetTopic {
  id        Int               @id @default(autoincrement())
  title     String
  slug      String            @unique
  sortOrder Int               @default(0)
  createdAt DateTime          @default(now())
  documents VargjetDocument[]
}

model VargjetDocument {
  id               Int          @id @default(autoincrement())
  topicId          Int
  topic            VargjetTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  title            String
  originalFileName String
  mimeType         String
  fileData         Bytes
  createdAt        DateTime     @default(now())

  @@index([topicId])
}